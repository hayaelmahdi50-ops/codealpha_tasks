              <calculation class='tableau' formula='DATENAME(&apos;month&apos;, MAKEDATE(2024,[MONTH],1))' />
            </column>
            <column caption='Avg Delay by Month' datatype='real' name='[Calculation_1284843063201794]' role='measure' type='quantitative'>
